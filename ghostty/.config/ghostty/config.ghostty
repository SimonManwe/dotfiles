# Terminal styling
background-opacity = 0.8
theme = Builtin Pastel Dark
window-decoration = false

# Fonts
font-size = 12.5
font-family = FiraCode Nerd Font
font-feature = +calt
font-feature = +liga

# Shell
command = /bin/zsh

# URL settings
link-url = true

# Mouse settings
mouse-hide-while-typing = true

# Scrollback
scrollback-limit = 10000

# Colors
background =#000000
foreground =#00a595
cursor-color =#bbbbbb
selection-background =#00a48c
selection-foreground =#000000
bold-is-bright = true

# Normal colors (0-7)
palette = 0=#000000
palette = 1=#9f0000
palette = 2=#008b00
palette = 3=#ffcf00
palette = 4=#0081ff
palette = 5=#bc00ca
palette = 6=#008b8b
palette = 7=#ffffff

# Bright colors (8-15)
palette = 8=#545454
palette = 9=#ff0000
palette = 10=#00ee00
palette = 11=#ffff00
palette = 12=#89b4fa
palette = 13=#ff00ff
palette = 14=#00cdcd
palette = 15=#ffffff
